# TempoCode — root .env for docker compose.
# Copy this file to `.env` (same directory) and fill in your values.
# Never commit `.env` to GitHub. (.gitignore already covers it.)

# Get a free key at https://console.groq.com — each developer should use their own.
GROQ_API_KEY=your-groq-api-key-here

# Postgres password for the local containerized DB.
# The default below is fine for development; change it for anything public.
POSTGRES_PASSWORD=tempocode

# Optional overrides (defaults work fine).
# STEP_GRADER_BASE_URL=https://api.groq.com/openai/v1
# STEP_GRADER_MODEL=llama-3.3-70b-versatile
