# Bare-metal dev only (running uvicorn directly without docker compose).
# For the Docker workflow, use the root .env.example instead.
#
# Copy this file to backend/.env and fill in your values.
# Never commit .env to GitHub.

DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/tempocode

# Get a free key at https://console.groq.com — each developer should use their own.
GROQ_API_KEY=your-groq-api-key-here
STEP_GRADER_BASE_URL=https://api.groq.com/openai/v1
STEP_GRADER_MODEL=llama-3.3-70b-versatile
